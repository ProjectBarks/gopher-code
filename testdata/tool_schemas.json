  {
    "name": "LSP",
    "description": "Language Server Protocol integration for code intelligence.",
    "is_read_only": true,
    "is_concurrency_safe": true,
    "max_result_size_chars": 100000,
    "input_schema": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "enum": [
            "goToDefinition",
            "findReferences",
            "hover",
            "documentSymbol",
            "workspaceSymbol",
            "goToImplementation",
            "prepareCallHierarchy",
            "incomingCalls",
            "outgoingCalls"
          ],
          "description": "The LSP operation to perform"
        },
        "filePath": {
          "type": "string",
          "description": "The absolute or relative path to the file"
        },
        "line": {
          "type": "number",
          "description": "The line number (1-based)"
        },
        "character": {
          "type": "number",
          "description": "The character offset (1-based)"
        }
      },
      "required": ["operation", "filePath", "line", "character"],
      "additionalProperties": false
    }
  },
  {
    "name": "NotebookEdit",
    "description": "Edit Jupyter notebook cells.",
    "is_read_only": false,
    "is_concurrency_safe": false,
    "max_result_size_chars": 100000,
    "input_schema": {
      "type": "object",
      "properties": {
        "notebook_path": {
          "type": "string",
          "description": "The absolute path to the Jupyter notebook file to edit"
